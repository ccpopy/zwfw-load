{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zwfw-load",
  "version": "2026.6.5",
  "identifier": "cn.linmew.zwfw-load",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "代理管理系统",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
